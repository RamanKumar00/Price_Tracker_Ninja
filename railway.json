    "dockerfilePath": "price_ninja_backend/Dockerfile",
    "context": "price_ninja_backend"
  },
  "deploy": {
    "numReplicas": 1,
    "sleepService": false,
    "restartPolicyType": "ON_FAILURE"
  }
}
